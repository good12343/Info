generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// 👤 USER TYPES
//////////////////////////////////////////////////////

enum UserCategory {
  AIRDROP_ONLY      // 🪂 حصل على Airdrop فقط
  AIRDROP_BUYER     // 🪂🛒 حصل على Airdrop واشترى
  BUYER_ONLY        // 🛒 اشترى فقط
  NONE              // ❌ لا شيء
}

enum UserTier {
  BRONZE    // 0 - 1,000 نقطة
  SILVER    // 1,001 - 5,000
  GOLD      // 5,001 - 10,000
  PLATINUM  // 10,001+
}

//////////////////////////////////////////////////////
// 👤 USER CORE (State Layer)
//////////////////////////////////////////////////////

model User {
  wallet            String   @id

  // 📊 Financial state
  totalBought       Int      @default(0)     // إجمالي المشتريات بالدولار
  airdropPoints     Int      @default(0)     // نقاط Airdrop
  tokensAllocated   String   @default("0")   // توكنز مخصصة (Airdrop)
  tokensBought      String   @default("0")   // توكنز مشتراة
  vestedTokens      String   @default("0")   // توكنز في Vesting
  claimableTokens   String   @default("0")   // قابلة للسحب

  // 🏷️ Classification
  category          UserCategory @default(NONE)
  tier              UserTier     @default(BRONZE)
  
  // 🔐 Business rules
  isEligible        Boolean  @default(false)
  isBlocked         Boolean  @default(false)
  isWhitelisted     Boolean  @default(false)

  // 🌍 GLOBAL CLAIM STATE
  hasClaimed        Boolean  @default(false)
  claimedAt         DateTime?
  claimTxHash       String?
  
  // 🛒 Purchase tracking
  purchaseCount     Int      @default(0)
  totalSpentUsd     String   @default("0")
  firstPurchaseAt   DateTime?
  lastPurchaseAt    DateTime?

  // 🌳 Merkle Tree Data (Airdrop)
  merkleProof       String[]
  merkleLeaf        String
  amount            String   @default("0")
  chainId           Int      @default(11155111)

  // 🧠 Risk / Anti-sybil
  riskScore         Float    @default(0)
  ipAddress         String?
  deviceFingerprint String?

  // 📦 Metadata
  sources           Json?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([category])
  @@index([tier])
  @@index([isEligible])
  @@index([hasClaimed])
  @@index([isBlocked])
  @@index([chainId])
}

//////////////////////////////////////////////////////
// 🛒 PURCHASE RECORDS
//////////////////////////////////////////////////////

model Purchase {
  id          String   @id @default(uuid())
  
  userId      String
  txHash      String
  
  // 💰 Purchase details
  amountUsd   String   // المبلغ بالدولار
  tokenAmount String   // كمية التوكنز
  tokenPrice  String   // سعر التوكنز وقت الشراء
  currency    String   @default("ETH") // ETH, USDC, etc.
  
  // ⏰ Timing
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([txHash])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// 📜 AUDIT LOG
//////////////////////////////////////////////////////

model AuditLog {
  id        String   @id @default(uuid())

  action    String   // CLAIM, PURCHASE, SET_ROOT, BLOCK_USER, etc
  userId    String?
  txHash    String?
  ip        String?
  chainId   Int      @default(11155111)

  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([chainId])
}

//////////////////////////////////////////////////////
// 🛡️ SYBIL PROTECTION
//////////////////////////////////////////////////////

model SybilCheck {
  id          String   @id @default(uuid())

  userId      String
  fingerprint String?
  ipAddress   String?

  claimCount  Int      @default(0)
  riskScore   Float    @default(0)
  blocked     Boolean  @default(false)

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([fingerprint])
}

//////////////////////////////////////////////////////
// 🌳 MERKLE SNAPSHOT
//////////////////////////////////////////////////////

model MerkleSnapshot {
  id          String   @id @default(uuid())
  
  root        String
  chainId     Int      @default(11155111)
  totalUsers  Int
  totalAmount String
  
  // 🏷️ Snapshot metadata
  category    UserCategory // أي صنف هذا الـ Snapshot
  tier        UserTier?    // أي Tier (اختياري)
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  @@index([root])
  @@index([isActive])
  @@index([chainId])
  @@index([category])
}

//////////////////////////////////////////////////////
// 📊 ANALYTICS / REPORTS
//////////////////////////////////////////////////////

model CategoryStats {
  id            String   @id @default(uuid())
  
  date          DateTime @default(now())
  category      UserCategory
  
  userCount     Int
  totalTokens   String
  avgTokens     String
  claimedCount  Int
  claimRate     Float
  
  @@index([date])
  @@index([category])
}