generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// 👤 USER TYPES & ENUMS
//////////////////////////////////////////////////////

enum UserCategory {
  AIRDROP_ONLY
  BUYER_ONLY
  AIRDROP_BUYER
  NONE
}

enum UserTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

//////////////////////////////////////////////////////
// 👤 USER CORE (Refactored to use UUID as PK)
//////////////////////////////////////////////////////

model User {
  id                String       @id @default(uuid())
  wallet            String       @unique // المحفظة فريدة ولكن ليست PK
  category          UserCategory @default(NONE)
  tier              UserTier     @default(BRONZE)
  
  // 📊 Airdrop State
  airdropPoints     Int          @default(0)
  airdropAllocated  Decimal      @default(0)
  airdropAllocatedWei String     @default("0")
  hasClaimedAirdrop Boolean      @default(false)
  airdropClaimedAt  DateTime?
  airdropTxHash     String?
  
  // 🛒 Purchase State
  totalBoughtUsd    Decimal      @default(0)
  purchaseCount     Int          @default(0)
  hasClaimedTokens  Boolean      @default(false)
  tokensClaimedAt   DateTime?
  tokensClaimTxHash String?
  
  // 🌳 Merkle Tree
  merkleProof       String[]
  merkleLeaf        String?
  chainId           Int          @default(11155111)
  
  // 🛡️ Security & Meta
  isBlocked         Boolean      @default(false)
  riskScore         Float        @default(0)
  lastIp            String?
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relationships
  purchases         Purchase[]
  airdropClaims     AirdropClaim[]
  vestingClaims     VestingClaim[]
  auditLogs         AuditLog[]
  userTasks         UserTask[]
  riskLogs          RiskLog[]
  fraudLogs         FraudLog[]
  reviewQueue       ReviewQueue[]

  @@index([wallet])
  @@index([category])
}

//////////////////////////////////////////////////////
// 🪂 AIRDROP CLAIM RECORDS
//////////////////////////////////////////////////////

model AirdropClaim {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  txHash      String   @unique
  amountWei   String
  amountFor   Decimal
  
  createdAt   DateTime @default(now())

  @@index([userId])
}

//////////////////////////////////////////////////////
// 🛒 PURCHASE RECORDS
//////////////////////////////////////////////////////

model Purchase {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  txHash      String   @unique
  amountUsd   Decimal
  tokenAmount Decimal
  tokenAmountWei String
  tokenPrice  Decimal
  currency    String   @default("ETH")
  
  createdAt   DateTime @default(now())

  @@index([userId])
}

//////////////////////////////////////////////////////
// 🔓 VESTING CLAIM RECORDS
//////////////////////////////////////////////////////

model VestingClaim {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  txHash      String   @unique
  amountWei   String
  amountFor   Decimal
  
  createdAt   DateTime @default(now())

  @@index([userId])
}

//////////////////////////////////////////////////////
// 🧭 TASK SYSTEM
//////////////////////////////////////////////////////

model Task {
  id          String   @id
  title       String
  description String?
  points      Int
  platform    String   // X, TELEGRAM, YOUTUBE
  category    String   // SOCIAL, VIDEO, ARTICLE
  url         String?
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userTasks   UserTask[]
}

model UserTask {
  id          String   @id @default(uuid())
  userId      String
  taskId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  status      String   @default("PENDING") // PENDING, VERIFIED, REJECTED, REVIEW
  rewardGiven Boolean  @default(false)

  ip          String?
  userAgent   String?
  metadata    Json?

  completedAt DateTime @default(now())

  @@unique([userId, taskId])
  @@index([userId])
  @@index([taskId])
}

//////////////////////////////////////////////////////
// 🛡️ RISK & FRAUD SYSTEM
//////////////////////////////////////////////////////

model RiskLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String?

  score       Int
  reason      String
  ip          String?
  userAgent   String?
  action      String

  createdAt   DateTime @default(now())

  @@index([userId])
}

model ReviewQueue {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String?

  reason      String
  riskScore   Int
  status      String   @default("PENDING")

  createdAt   DateTime @default(now())
  reviewedAt  DateTime?

  @@index([userId])
}

model FraudLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  taskId      String?

  type        String
  severity    String
  ip          String?
  metadata    Json?

  createdAt   DateTime @default(now())

  @@index([userId])
}

//////////////////////////////////////////////////////
// 📜 AUDIT LOG
//////////////////////////////////////////////////////

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  
  txHash    String?
  metadata  Json?
  ip        String?
  
  createdAt DateTime @default(now())

  @@index([userId])
}

//////////////////////////////////////////////////////
// 📊 ANALYTICS
//////////////////////////////////////////////////////

model DailyStats {
  id            String   @id @default(uuid())
  date          DateTime @unique @default(now())
  
  totalUsers    Int
  totalAirdrop  Decimal
  totalPurchased Decimal
  claimedAirdrop Int
  claimedTokens  Int
  
  createdAt     DateTime @default(now())
}
